# 테스트 7
class Pet:
    def __init__(self,name,species):
        """펫을 생성"""
        self.name = name
        self.species = species
        self.hunger = 50 # 초기 배고픔 수치 ( 0 ~ 100)
    def feed(self):
        """밥을 주면 배고픔 감소"""
        if self.hunger > 10:
            self.hunger -= 10
        return f"{self.name}에게 밥을 줬습니다.! 배고픔:{self.hunger}"
    def play(self):
        """놀아주면 배고픔이 증가"""
        if self.hunger < 80:
            self.hunger += 20
        return f"{self.name}와 아주 잘 놀아줬어요!!!!~~~~ 배고픔:{self.hunger}"   
    


