# 클래스 구성
class Calculator:
    def __init__(self):
        self.result = 0
    def add(self, num):      
        self.result += num
        return self.result
    def sub(self, num):
        self.result -= num
        return self.result

# 인스턴스화
cal1 = Calculator() # [1,2,3,4,5]
cal2 = Calculator() # ['a','b']
print('1:',cal1.add(1))
print('2:',cal2.add(1))
print('2:',cal2.add(1))
print('2:',cal2.add(1))
print('1:',cal1.add(1))
print('1:',cal1.add(1))

print('2:',cal2.sub(1))
print('2:',cal2.sub(1))





# 예제1
class Dduk:
    def __init__(self, won , ea):
        self.won = won
        self.ea = ea
    def dduk(self):
        result = self.won * self.ea
        print( f"배가 고파서 떡볶이집에서 떡볶이를 {result}원어치 먹었다.")
    def odeng(self):
        result = self.won * 2 * self.ea
        print( f"배가 고파서 떡볶이집에서 오뎅을 {result}원어치 먹었다.")


성훈 = Dduk(2000,3)
희성 = Dduk(3000,2)
기윤 = Dduk(1500,6)


성훈.dduk()
성훈.odeng()


희성.dduk()
희성.odeng()


기윤.dduk()
기윤.odeng()


성훈.__init__(3300,2)


성훈.dduk()
성훈.odeng()





